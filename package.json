{
  "name": "keepass-studio-electron",
  "version": "8.4.0",
  "description": "Google Sheets to KeePass desktop studio built with Electron, React and Python.",
  "main": "electron/main.cjs",
  "author": "KeePass Studio",
  "license": "GPL-3.0-or-later",
  "private": true,
  "packageManager": "npm@10.9.2",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "build": "vite build",
    "preview": "vite preview",
    "electron": "electron .",
    "dist:portable": "npm run build && electron-builder --win portable --x64",
    "dist:installer": "npm run build && electron-builder --win nsis --x64",
    "dist:all": "npm run build && electron-builder --win portable nsis --x64"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.6.0",
    "concurrently": "^9.2.0",
    "cross-env": "^10.1.0",
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12",
    "vite": "^7.0.0",
    "wait-on": "^8.0.4"
  },
  "build": {
    "appId": "com.keepassstudio.desktop",
    "productName": "KeePass Studio",
    "asar": true,
    "compression": "normal",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "backend-dist/keepass_backend.exe",
        "to": "backend/keepass_backend.exe"
      },
      {
        "from": "build/icon.ico",
        "to": "icon.ico"
      },
      {
        "from": "build/icon.png",
        "to": "icon.png"
      }
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "portable",
        "nsis"
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "portable": {
      "artifactName": "KeePassStudio-Portable-${version}-${arch}.${ext}"
    },
    "nsis": {
      "artifactName": "KeePassStudio-Setup-${version}-${arch}.${ext}",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "KeePass Studio",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "deleteAppDataOnUninstall": false,
      "displayLanguageSelector": false,
      "installerLanguages": [
        "zh_CN"
      ]
    }
  }
}
